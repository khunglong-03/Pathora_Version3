# ASP.NET Core
Auth__DisableAuthorization=true
Dev__EnableDevEndpoints=true
Dev__DevApiKey=replace-with-dev-api-key
Dev__ResetAndReseedOnStartup=false

# Serilog
Serilog__MinimumLevel__Default=Information
SERILOG_OVERRIDE_MICROSOFT_ASPNETCORE_MVC=Warning
SERILOG_OVERRIDE_MICROSOFT_ASPNETCORE_ROUTING=Warning
SERILOG_OVERRIDE_MICROSOFT_ASPNETCORE_HOSTING=Warning
SERILOG_OVERRIDE_ZIGGYCREATURES_CACHING_FUSION=Warning
SERILOG_OVERRIDE_SYSTEM_NET_HTTP=Warning

# CORS
Cors__AllowedOrigins__0=http://localhost:3001
Cors__AllowedOrigins__1=http://localhost:3000
Cors__AllowedOrigins__2=http://127.0.0.1:3001
Cors__AllowedOrigins__3=http://127.0.0.1:3000
Cors__AllowedOrigins__4=http://localhost:4001
Cors__AllowedOrigins__5=https://localhost:3001
Cors__AllowedOrigins__6=https://localhost:3000
Cors__AllowedOrigins__7=https://localhost:4001
Cors__AllowedOrigins__8=https://pathora-api.duckdns.org
Cors__AllowedOrigins__9=http://pathora-api.duckdns.org
Cors__AllowedOrigins__10=https://pathora-fe.duckdns.org
Cors__AllowedOrigins__11=https://pathora-git-main-thehieu03s-projects.vercel.app

# Connection strings
ConnectionStrings__Default=Host=localhost;Port=5432;Database=PanthoraDb;Username=postgres;Password=replace-with-db-password;SSL Mode=Disable
Redis__ConnectionString=localhost:6379,abortConnect=False

# App config
AppConfig__ServiceName=Panthora API
AppConfig__FrontendBaseUrl=http://localhost:3000
AppConfig__SwaggerBaseUrl=http://localhost:8080
AppConfig__IncludeInnerException=false
AppConfig__IncludeExceptionStackTrace=false

# Swagger
SwaggerGen__Title=Panthora Backend API
SwaggerGen__Version=v1
SwaggerGen__Description=API documentation for Panthora backend services
SwaggerGen__ContactName=Panthora Team
SwaggerGen__ContactEmail=replace-with-contact-email@example.com
SwaggerGen__dev=Nguyen The Hieu
SwaggerGen__ContactUrl=https://example.com/contact

# JWT
Jwt__Secret=replace-with-64-plus-char-secret
Jwt__Issuer=http://localhost:8080
Jwt__Audience=http://localhost:8080
Jwt__ExpireInMinutes=15
Jwt__AccessTokenCookieExpirationHours=1
Jwt__RefreshTokenExpirationHours=168

# External services
Cloudinary__CloudName=replace-with-cloudinary-cloud-name
Cloudinary__ApiKey=replace-with-cloudinary-api-key
Cloudinary__ApiSecret=replace-with-cloudinary-api-secret
Cloudinary__DefaultFolder=panthora

Mail__Host=smtp.gmail.com
Mail__Port=587
Mail__UseAuthentication=true
Mail__UserName=replace-with-mail-username
Mail__Password=replace-with-mail-password

Authentication__Google__ClientId=replace-with-google-client-id
Authentication__Google__ClientSecret=replace-with-google-client-secret
OpenTelemetry__Endpoint=http://localhost:4318

# Payment providers
VietQR__ApiUrl=https://api.vietqr.io/image/
VietQR__BankBin=970422
VietQR__AccountNo=0868430273
VietQR__AccountName=GORNER ROBIN
VietQR__TemplateId=U4NCcYH

# SePay Configuration (canonical)
SePay__ApiUrl=https://my.sepay.vn
SePay__AccountNumber=0868430273
SePay__ApiKey=YOUR_SEPAY_API_KEY
SePay__WebhookSecret=YOUR_SEPAY_WEBHOOK_SECRET
SePay__AllowedIps=

# Payment (DEPRECATED — Use SePay:* keys above instead)
Payment__Account=0868430273
Payment__Bank=MB
Payment__AuthenticationKey=replace-with-payment-authentication-key
Payment__ApiBaseUrl=https://my.sepay.vn
Payment__QrBaseUrl=https://qr.sepay.vn/img
Payment__PollingLimit=20
Payment__PollingIntervalSeconds=30
Payment__SepayWebhookSecret=replace-with-payment-sepay-webhook-secret
Payment__RateLimitSeconds=5

# Workers
OutboxWorker__PollingIntervalMs=30000
OutboxWorker__BatchSize=10
OutboxWorker__MaxRetries=10
