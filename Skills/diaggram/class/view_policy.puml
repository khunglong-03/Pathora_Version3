@startuml View Policy
skinparam classAttributeIconSize 0

package "API" {
    class PolicyController {
        +GetPricingPolicy(id: Guid): Task<IActionResult>
        +GetCancellationPolicy(id: Guid): Task<IActionResult>
        +GetDepositPolicy(id: Guid): Task<IActionResult>
    }
}

package "Application" {
    interface IPricingPolicyService {
        +GetByIdAsync(id: Guid): Task<ErrorOr<PricingPolicyResponse>>
    }
    interface ICancellationPolicyService {
        +GetByIdAsync(id: Guid): Task<ErrorOr<CancellationPolicyResponse>>
    }
    interface IDepositPolicyService {
        +GetByIdAsync(id: Guid): Task<ErrorOr<DepositPolicyResponse>>
    }
}

package "Domain" {
    class PricingPolicyEntity { +Id: Guid; +Name: string }
    class CancellationPolicyEntity { +Id: Guid; +Name: string }
    class DepositPolicyEntity { +Id: Guid; +Name: string }
}

PolicyController ..> IPricingPolicyService : uses
PolicyController ..> ICancellationPolicyService : uses
PolicyController ..> IDepositPolicyService : uses
@enduml
